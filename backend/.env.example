# ============================================================
#  AI PROVIDER
#  Pick where the chatbot + report generation runs.
# ============================================================

# LLM_PROVIDER: ollama (local) | groq (cloud) | hermes (Nous Research) | openai
LLM_PROVIDER=ollama

# --- If LLM_PROVIDER=ollama (default, runs on your machine) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# --- If LLM_PROVIDER=groq (free hosted — get a key at console.groq.com) ---
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# --- If LLM_PROVIDER=hermes (Nous Research, OpenAI-compatible) ---
# Fill these when they hand you the Hermes endpoint + key, then set LLM_PROVIDER=hermes.
# HERMES_BASE_URL=https://your-hermes-endpoint/v1
# HERMES_API_KEY=
# HERMES_MODEL=Hermes-3-Llama-3.1-70B

# --- If LLM_PROVIDER=openai ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ============================================================
#  EMBEDDINGS (for the RAG notes search)
#  Groq has no embeddings API — when hosting on Groq, embed via
#  Ollama (if reachable) or OpenAI.
# ============================================================

# EMBED_PROVIDER: ollama (local, free) | openai (cloud, cheap)
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
# OPENAI_EMBED_MODEL=text-embedding-3-small

# ============================================================
#  GITHUB (optional — only for syncing real repos)
# ============================================================
# GITHUB_TOKEN=ghp_...

# ============================================================
#  EMAIL + CALENDAR — Microsoft 365 (optional)
#  Lets each person connect their own inbox so the AI can read mail AND
#  write events to their Outlook calendar (email → calendar feature).
#  Register an app at portal.azure.com (Entra ID > App registrations), add
#  delegated Graph permissions: Mail.Read, Calendars.ReadWrite, User.Read, offline_access.
# ============================================================
# MS_CLIENT_ID=...
# MS_CLIENT_SECRET=...
# MS_TENANT_ID=common
# MS_REDIRECT_URI=http://localhost:8000/api/email/callback
# FRONTEND_URL=http://localhost:3000

# ============================================================
#  AUTH + ROLES (login / sign-in)
#  Login reuses the SAME Microsoft app above. Add the login redirect URI
#  http://localhost:8000/api/auth/callback (and your prod one) in Entra.
# ============================================================
# SESSION_SECRET=                 # long random string; signs session cookies
# AUTH_ENFORCED=false             # false = open (demo). true = require login + check roles
# FIRST_ADMIN_EMAIL=             # this email becomes admin on first sign-in
# MS_LOGIN_REDIRECT_URI=http://localhost:8000/api/auth/callback
# COOKIE_SECURE=true             # set false for local http so the session cookie sticks

# ============================================================
#  NOTIFICATIONS — how the AI reaches people (channel TBD)
#  console (default) | wechat_work | twilio | teams
# ============================================================
# NOTIFY_CHANNEL=console
# --- wechat_work (企业微信 — company edition; personal WeChat has no bot API) ---
# WECOM_CORP_ID=
# WECOM_AGENT_ID=
# WECOM_SECRET=
# --- twilio (SMS) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# --- teams (incoming webhook) ---
# TEAMS_WEBHOOK_URL=
