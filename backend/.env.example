# Optional: GitHub Personal Access Token (needed for private repos or higher rate limits)
# Without this, public repos work at 60 req/hour. Leave blank for public repos.
GITHUB_TOKEN=

# Optional: Ollama model to use (default: llama3.2)
# For better analysis quality, use: llama3.1:8b or qwen2.5:7b
OLLAMA_MODEL=llama3.2

# Optional: Ollama base URL (default: http://localhost:11434/v1)
OLLAMA_BASE_URL=http://localhost:11434/v1
