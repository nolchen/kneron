# ============================================================
#  AI PROVIDER
#  Pick where the chatbot + report generation runs.
# ============================================================

# LLM_PROVIDER: ollama (local, free) | groq (cloud, free tier) | openai (cloud, paid)
LLM_PROVIDER=ollama

# --- If LLM_PROVIDER=ollama (default, runs on your machine) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# --- If LLM_PROVIDER=groq (free hosted — get a key at console.groq.com) ---
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# --- If LLM_PROVIDER=openai ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ============================================================
#  EMBEDDINGS (for the RAG notes search)
#  Groq has no embeddings API — when hosting on Groq, embed via
#  Ollama (if reachable) or OpenAI.
# ============================================================

# EMBED_PROVIDER: ollama (local, free) | openai (cloud, cheap)
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
# OPENAI_EMBED_MODEL=text-embedding-3-small

# ============================================================
#  GITHUB (optional — only for syncing real repos)
# ============================================================
# GITHUB_TOKEN=ghp_...

# ============================================================
#  EMAIL — Microsoft 365 (optional)
#  Lets each person connect their own inbox so the AI can read it.
#  Register an app at portal.azure.com (Entra ID > App registrations),
#  add delegated Graph permissions: Mail.Read, User.Read, offline_access.
# ============================================================
# MS_CLIENT_ID=...
# MS_CLIENT_SECRET=...
# MS_TENANT_ID=common
# MS_REDIRECT_URI=http://localhost:8000/api/email/callback
# FRONTEND_URL=http://localhost:3000
