[Unit]
# PM Agent — FastAPI backend (API + database).
# Adjust User, WorkingDirectory, and the venv path to your machine, then:
#   sudo cp deploy/pm-agent-backend.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now pm-agent-backend
Description=PM Agent backend (FastAPI)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pmagent
WorkingDirectory=/opt/pm-agent/backend
# Loads GROQ_API_KEY, Microsoft creds, COOKIE_SECURE=false, etc.
EnvironmentFile=/opt/pm-agent/backend/.env
ExecStart=/opt/pm-agent/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
